# URL внешнего сервиса для логирования статусов операций
# Сюда отправляется информация об успешности/ошибках сбора данных
# Используется для мониторинга работы воркеров
LOGGING_URL="http://mock_server-logging:8082/log"

# Интервал опроса метеостанций в секундах
# Через каждые 10 секунд воркеры будут запрашивать новые данные со станций
PULL_INTERVAL=10

# Таймаут HTTP запросов к метеостанциям в секундах
# Если станция не отвечает в течение 5 секунд - запрос прерывается
TIMEOUT=5

# Количество повторных попыток при ошибках запроса
# 0 означает, что повторные попытки не выполняются
# При ошибке запрос сразу считается неудачным
RETRY_COUNT=0

# Задержка между повторными попытками в секундах
# Если RETRY_COUNT > 0, то перед следующей попыткой будет пауза 3 секунды
RETRY_DELAY=3